{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "GpsDmc/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/GpsDmc/dist/assets/$1"
    },
    {
      "src": "/vite.svg",
      "dest": "/GpsDmc/dist/vite.svg"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2))",
      "dest": "/GpsDmc/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/GpsDmc/dist/index.html"
    }
  ]
}
